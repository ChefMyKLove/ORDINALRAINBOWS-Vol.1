# Copy this file to `.env` and fill in real values locally. NEVER commit real secrets.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key  # used by local admin scripts

# Treasury / payout
TREASURY_ADDRESS=1YourTreasuryReceiveAddress
# Option A: use a WIF or mnemonic locally (RECOMMENDED: keep offline, never push to git)
# TREASURY_WIF=your_private_wif_here
# TREASURY_MNEMONIC="abandon abandon ..."

# Vercel: the frontend will read SUPABASE_URL and SUPABASE_ANON_KEY from Vercel env
